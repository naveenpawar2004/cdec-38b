pipeline {
   agent any 
    stages {
      stage ('pull-stage') {
       steps {
           git branch: 'main', url: 'https://github.com/shubhamkalsait/EasyCRUD.git'
       }
      }
      stage ('build-stage') {
       steps {
            sh '''cd backend
               mvn clean package -DskipTests'''
       }
      }
      stage('test-stage') {
       steps {
          withSonarQubeEnv(installationName: 'server', credentialsId: 'cred-sonar') {
           sh '''cd backend
               mvn sonar:sonar -Dsonar.projectKey=studentdb'''
         }
    }
}
      stage('quality-stage') {
       steps {
          waitForQualityGate abortPipeline: true, credentialsId: 'cred-sonar'  
       }
         }
         stage ('depliver-stage') {
       steps {
           sh 'aws s3 cp backend/target/student.jar s3://jenkins-to-s3-17/student.app
       }
      }
    }
}
 
