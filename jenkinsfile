pipeline {
   agent any 
    stages {
      stage ('pull-stage') {
       steps {
          git branch: 'main', url: 'https://github.com/naveenpawar2004/cdec-38b.git'
       }
      }
      stage ('build-stage') {
       steps {
          dir('backend') {
                    sh 'mvn clean package -DskipTests'
                }
       }
      }
    }
}
